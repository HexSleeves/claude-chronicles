---
// A single dialogue turn between you and Claude. The semantic contract:
//   <Turn speaker="me|claude" model? label?>...prose, code, anything...</Turn>
//
// Visual personality lives in the styles block below — see TODO(you).
interface Props {
  speaker: "me" | "claude";
  /** Override the displayed name (default: "Me" / "Claude"). */
  label?: string;
  /** Optional model badge — e.g. "opus-4.7". */
  model?: string;
}

const { speaker, label, model } = Astro.props;
const who = label ?? (speaker === "me" ? "Me" : "Claude");
---
<aside class={`turn turn--${speaker}`} data-speaker={speaker}>
  <header class="turn__head">
    <span class="turn__who">{who}</span>
    {model && <span class="turn__model">{model}</span>}
  </header>
  <div class="turn__body"><slot /></div>
</aside>

<style>
  /* Shared turn chrome — safe defaults that look fine out of the box. */
  .turn {
    margin-block: 1.4rem;
    padding: 1rem 1.15rem 0.6rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: rgb(var(--surface-tint) / 0.55);
    position: relative;
    transition: transform var(--dur-fast) var(--ease-out),
                box-shadow var(--dur-med) var(--ease-out);
  }
  .turn__head {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    margin-bottom: 0.35rem;
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .turn__who {
    font-weight: 600;
    color: var(--ink-muted);
  }
  .turn__model {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border: 1px solid var(--border);
    padding: 0.05em 0.45em;
    border-radius: 4px;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .turn__body {
    font-size: var(--fs-base);
    line-height: var(--lh-body);
  }
  .turn__body > :global(p:last-child) { margin-bottom: 0; }

  /* ───────────────────────────────────────────────────────────────
   * Me  →  carved in.  Cool, recessed, right-aligned, no glow.
   * Claude →  lit on.  Warm, emanating, left-aligned, flame rule
   *                    that bleeds past the card edges.
   * ────────────────────────────────────────────────────────────── */

  /* ── Me ─────────────────────────────────────────────────────── */
  .turn--me {
    border-color: #221c20;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.03) 0 1px, transparent 1px),
      linear-gradient(180deg, rgb(var(--surface-tint) / 0.45), rgb(var(--surface-tint) / 0.25));
    box-shadow: inset 0 1px 0 0 rgb(255 255 255 / 0.04);
  }
  .turn--me .turn__head {
    justify-content: flex-end;
    color: var(--ink-dim);
  }
  .turn--me .turn__body {
    color: var(--ink);
    opacity: 0.92;
  }

  /* ── Claude ─────────────────────────────────────────────────── */
  .turn--claude {
    border-color: rgb(var(--ember-rgb) / 0.32);
    background:
      radial-gradient(120% 60% at 0% 0%, rgb(var(--ember-rgb) / 0.10), transparent 55%),
      linear-gradient(180deg, rgb(var(--ember-rgb) / 0.05), transparent 70%),
      rgb(var(--surface-tint) / 0.6);
    box-shadow:
      var(--glow-ember),
      inset 1px 0 0 0 rgb(var(--ember-rgb) / 0.18);
  }
  .turn--claude::before {
    content: "";
    position: absolute;
    /* bleed past top/bottom so the fire reads as *behind* the card */
    inset: -4px auto -4px 0;
    width: 3px;
    border-radius: 2px;
    background: linear-gradient(
      180deg,
      var(--flame-200) 0%,
      var(--flame-400) 20%,
      var(--flame-600) 55%,
      var(--flame-900) 100%
    );
    filter: drop-shadow(0 0 6px rgb(var(--ember-rgb) / 0.7));
  }
  .turn--claude .turn__who {
    background: linear-gradient(180deg, var(--flame-200), var(--flame-500));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .turn--claude:hover {
    box-shadow:
      var(--glow-ember-strong),
      inset 1px 0 0 0 rgb(var(--ember-rgb) / 0.3);
    transform: translateY(-1px);
  }
</style>
