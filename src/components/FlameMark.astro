  height={size}
  viewBox="0 0 24 24"
  role="img"
  aria-label={title}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="flame-grad" x1="12" y1="2" x2="12" y2="22" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="var(--flame-50)" />
