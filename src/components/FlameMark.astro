  </defs>
  <path
    d="M12 2c1.6 3.4-1.2 5.6-1.2 8.2 0 1.7 1.2 2.7 2.6 2.7 1.5 0 2.4-1 2.4-2.4 0-.7-.2-1.4-.6-2.1 3 1.6 4.8 4.3 4.8 7.4 0 3.8-3.1 6.2-7 6.2s-7-2.4-7-6.2C6 11.3 9.3 7.5 12 2z"
