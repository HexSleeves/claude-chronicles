---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import FlameMark from "../components/FlameMark.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = "A blog of wild conversations with Claude.",
  ogImage,
  noIndex = false,
} = Astro.props;

const siteName = "claude chronicles";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage ?? `${base}/og-default.png`, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={`${base}/rss.xml`} />
    <meta name="theme-color" content="#0a0a0c" />

    <ClientRouter />
  </head>
  <body>
    <a href="#content" class="visually-hidden">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner container container--wide">
        <a class="brand" href={`${base}/`}>
          <FlameMark size={26} />
          <span class="brand__name">
            <span class="brand__claude">claude</span><span class="brand__dot">.</span>chronicles
          </span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href={`${base}/conversations/`}>Archive</a>
          <a href={`${base}/about/`}>About</a>
          <a href={`${base}/rss.xml`} rel="alternate" type="application/rss+xml">RSS</a>
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container container--wide">
        <p>
          <FlameMark size={16} />
          <span>burned by hand — &copy; {new Date().getFullYear()} HexSleeves</span>
        </p>
        <p class="site-footer__src">
          <a href="https://github.com/HexSleeves/claude-chronicles" rel="noopener">source</a>
        </p>
      </div>
    </footer>

    <style>
      /* ── Site header ────────────────────────────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        /* Lighter backdrop on mobile — blur is the most expensive
           single CSS effect on Android. Upgraded at 40em+. */
        backdrop-filter: blur(8px);
        background: rgb(10 10 12 / 0.78);
        border-bottom: 1px solid var(--border);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        padding-block: 0.4rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--ink);
        border: none;
        font-weight: 600;
        letter-spacing: -0.01em;
        min-height: 44px;       /* tap-target */
        padding-inline: 2px;
      }
      .brand:hover {
        color: var(--ember);
        text-shadow: 0 0 12px rgb(var(--ember-rgb) / 0.7);
      }
      .brand__name { font-size: 0.95rem; }
      .brand__claude { display: none; }       /* "claude" prefix hidden on narrow viewports */
      .brand__dot { color: var(--ember); }

      .nav {
        display: flex;
        gap: 0.25rem;
        font-size: var(--fs-sm);
        margin-inline-start: auto;       /* push to right when wrapping */
      }
      .nav a {
        color: var(--ink-muted);
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding-inline: 0.7rem;
        border-radius: 8px;
      }
      .nav a:hover { color: var(--ember); background: rgb(var(--ember-rgb) / 0.08); }
      .nav a:focus-visible {
        outline: 2px solid var(--ember);
        outline-offset: 2px;
      }

      @media (min-width: 26em) {
        .brand__claude { display: inline; }   /* full brand fits */
      }
      @media (min-width: 40em) {
        .site-header__inner { padding-block: 0.6rem; }
        .brand__name { font-size: 1rem; }
        .nav { gap: 0.5rem; }
        .nav a { padding-inline: 0.85rem; }
        .site-header { backdrop-filter: blur(12px) saturate(140%); background: rgb(10 10 12 / 0.62); }
      }

      /* ── Site footer ────────────────────────────────────────── */
      .site-footer {
        margin-top: 4rem;
        padding-block: 1.5rem;
        border-top: 1px solid var(--border);
        color: var(--ink-dim);
        font-size: var(--fs-sm);
      }
      .site-footer .container {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.6rem;
      }
      .site-footer p {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        margin: 0;
        flex-wrap: wrap;
      }
      .site-footer__src a {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding-inline: 4px;
      }
      @media (min-width: 40em) {
        .site-footer { margin-top: 6rem; padding-block: 2rem; }
        .site-footer .container {
          flex-direction: row;
          align-items: center;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 1rem;
        }
      }
    </style>
  </body>
</html>
